# OCI Authentication
# Uses a named profile from ~/.oci/config. Run `oci setup config` to configure.
oci_config_profile = "DEFAULT"

# Compartment (required — cannot be auto-detected)
compartment_ocid = "ocid1.compartment.oc1..aaaaaaaxxxxx"

# Tenancy (required — for budget creation)
tenancy_ocid = "ocid1.tenancy.oc1..aaaaaaaxxxxx"


# Region
region = "uk-london-1"

# Budget Alert Email
budget_alert_email = "your-email@example.com"

# ---------------------------------------------------------------------------
# Mode A: Plain Ubuntu instances (default — omni_ready = false)
#
# Ampere nodes boot Ubuntu 22.04. Connect via SSH using the provided key.
# micro_nodes can serve as a bastion or be suppressed with [].
# ---------------------------------------------------------------------------
# ssh_public_key = "ssh-ed25519 AAAA... user@host"
#
# ampere_nodes = [
#   { name = "app-1", ocpus = 2, memory_gb = 12, boot_vol_gb = 50 },
#   { name = "app-2", ocpus = 2, memory_gb = 12, boot_vol_gb = 50 },
# ]
# micro_nodes = [{ name = "bastion" }]

# ---------------------------------------------------------------------------
# Mode B: Talos + Omni + Tailscale (omni_ready = true)
#
# Ampere nodes boot Talos, connect to your Omni instance via SideroLink over
# Tailscale. No SSH key needed. No public Omni IP needed.
#
# Prerequisites:
#   1. Import Talos+Tailscale image to OCI:
#      a. Go to https://factory.talos.dev — select ARM64, add Tailscale extension
#      b. Download Oracle Cloud image variant
#      c. Import: scripts/oci-import.sh talos-arm64.raw.xz talos-omni-<version>
#      d. Set talos_image_ocid below (or store as GitHub variable TALOS_IMAGE_OCID)
#
#   2. Get join token (static, from your Omni instance):
#      omnictl get connections -o yaml | grep joinToken
#      Store as GitHub secret OMNI_JOIN_TOKEN.
#
#   3. Create Tailscale auth key at admin.tailscale.com:
#      - Reusable, tag: tag:talos
#      Store as GitHub secret NODES_TAILSCALE_AUTHKEY.
#
# After provisioning, label nodes in Omni then apply the cluster template:
#   omnictl machine set-labels <id> role=oci-cp    # x3
#   omnictl machine set-labels <id> role=oci-worker # x1
#   cd oci-talos-gitops-apps && omnictl apply -f omni/machine-classes/ && omnictl apply -f omni/cluster-templates/
# ---------------------------------------------------------------------------
omni_ready       = true
talos_image_ocid = "ocid1.image.oc1.uk-london-1.aaaaaaaa..."
# omni_machine_config and tailscale_auth_key are passed via CI secrets or -var flags:
#   tofu apply -var="omni_machine_config=$OMNI_MACHINE_CONFIG" -var="tailscale_auth_key=$NODES_TAILSCALE_AUTHKEY"

ampere_nodes = [
  { name = "oci-talos-cp-1",     ocpus = 1, memory_gb = 6, boot_vol_gb = 50 },
  { name = "oci-talos-cp-2",     ocpus = 1, memory_gb = 6, boot_vol_gb = 50 },
  { name = "oci-talos-cp-3",     ocpus = 1, memory_gb = 6, boot_vol_gb = 50 },
  { name = "oci-talos-worker-1", ocpus = 1, memory_gb = 6, boot_vol_gb = 50 },
]
micro_nodes = [] # No bastion — Omni SideroLink handles connectivity

# ---------------------------------------------------------------------------
# Load Balancer (optional — OCI provides 1 x 10 Mbps free)
# Useful for K8s ingress. Annotate Services with:
#   service.beta.kubernetes.io/oci-load-balancer-shape: "10Mbps"
# ---------------------------------------------------------------------------
# load_balancer = {}
