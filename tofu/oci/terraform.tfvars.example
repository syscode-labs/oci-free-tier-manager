# OCI Authentication
# Uses a named profile from ~/.oci/config. Run `oci setup config` to configure.
oci_config_profile = "syscode-homelab"

# Compartment (required — cannot be auto-detected)
compartment_ocid = "ocid1.compartment.oc1..aaaaaaaxxxxx"

# Adoption mode safety toggle (OFF by default).
# Set true only when adopting pre-created OCI resources into Terraform state.
adopt_existing_resources = false

# Region
region = "uk-london-1"

# Budget Alert Email
budget_alert_email = "your-email@example.com"

# ---------------------------------------------------------------------------
# Talos Omni image (required)
#
# 1. In Omni UI: Nodes → Download Installation Media → Oracle Cloud (ARM64)
#    This generates an image pre-configured with your Omni SideroLink endpoint.
# 2. Import it: OCI_COMPARTMENT_ID=<ocid> ./scripts/oci-import.sh talos-omni.raw.zst talos-omni-<version>
#    (Use oci-free-tier-images/scripts/oci-import.sh — sets UEFI_64 + PARAVIRTUALIZED)
# 3. Paste the resulting image OCID below.
# ---------------------------------------------------------------------------
talos_image_ocid = "ocid1.image.oc1.uk-london-1.aaaaaaaa..."

# ---------------------------------------------------------------------------
# Instance configuration — 4× Ampere for Talos cluster
#
# Layout: 3 control-plane + 1 worker, all mixed CP+worker via allow-scheduling.
# Total: 4 OCPUs / 24 GB RAM / 200 GB storage (maxes out free tier).
#
# After provisioning, label nodes in Omni and apply the cluster template:
#   omnictl machine set-labels <id> role=oci-cp    # ×3
#   omnictl machine set-labels <id> role=oci-worker # ×1
#   cd omni-oci-proxmox && mise run oci:machine-classes:apply && mise run oci:cluster:apply
# ---------------------------------------------------------------------------
ampere_nodes = [
  { name = "oci-talos-cp-1",     ocpus = 1, memory_gb = 6, boot_vol_gb = 50 },
  { name = "oci-talos-cp-2",     ocpus = 1, memory_gb = 6, boot_vol_gb = 50 },
  { name = "oci-talos-cp-3",     ocpus = 1, memory_gb = 6, boot_vol_gb = 50 },
  { name = "oci-talos-worker-1", ocpus = 1, memory_gb = 6, boot_vol_gb = 50 },
]
micro_nodes = []  # No bastion — Omni SideroLink handles connectivity

# ---------------------------------------------------------------------------
# Load Balancer (optional — OCI provides 1 × 10 Mbps free)
# Useful for K8s ingress. Annotate Services with:
#   service.beta.kubernetes.io/oci-load-balancer-shape: "10Mbps"
# ---------------------------------------------------------------------------
# load_balancer = {}
