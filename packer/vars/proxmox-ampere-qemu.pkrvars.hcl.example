# Vars for local QEMU build (requires ARM64 host with KVM, e.g. Apple M-series or Linux ARM64)
# For CI use, these are passed via GitHub Actions secrets/env vars

# SSH public key injected via cloud-init NoCloud into the build VM
ssh_public_key = "ssh-ed25519 AAAA... your-key"

# Debian 12 ARM64 genericcloud image (downloaded automatically if URL given)
# debian_image_url = "https://cloud.debian.org/images/cloud/bookworm/latest/debian-12-genericcloud-arm64.qcow2"
# debian_image_checksum = "none"

# Build VM resources (increase for faster builds on capable hardware)
memory = 4096
cpus   = 2
